{
  "name": "a2ui-oat",
  "version": "0.1.0",
  "description": "A lightweight A2UI renderer and catalog for agent-driven web interfaces, built on Oat CSS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate-catalog.js"
  },
  "main": "renderer/index.js",
  "exports": {
    ".": "./renderer/index.js",
    "./catalog": "./catalog/oat-catalog.json",
    "./sanitizer": "./direct/sanitizer.js"
  },
  "keywords": [
    "a2ui",
    "oat",
    "agent-ui",
    "a2a",
    "renderer",
    "lightweight",
    "framework-free"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MisterTK/a2ui-oat"
  },
  "author": "Thomas Kraus",
  "files": [
    "catalog/",
    "renderer/",
    "direct/",
    "shared/",
    "docs/"
  ]
}
